# Build artifacts
build/

# macOS metadata
.DS_Store

# LaTeX intermediates
*.aux
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz

# Python bytecode
scripts/__pycache__/
*.pyc

# ------------------------------------------------------------
# Personal data — exclude when pushing to a public repo.
# If this is a private repo (see PRIVACY.md Path B), you can
# comment out this block.
# ------------------------------------------------------------
raw/resumes/
raw/code/*.md
!raw/code/_TEMPLATE.md

# Derived PDF text cache + raw manifest. Regenerated by scripts/raw_cache.py
# on every `make draft`. Never the source of truth — cite original PDFs only.
raw/.cache/
jobs/
drafts/
approved/
edits/

# Personal style profile — example phrases reference specific projects
# (e.g. 3D micro-CT datasets, 70%--90% metrics). Kept local only.
preferences.md

# JD search runtime data — profiles and search results may contain personal
# targeting preferences and real application history. Keep templates only.
jd_search/profiles/*.json
!jd_search/profiles/example.json
jd_search/searches/
jd_search/decisions.tsv
jd_search/decisions.md
jd_search/persona.md
jd_search/seen.tsv
jd_search/inbox.md
jd_search/inbox/

# Personal LaTeX template override — kept local only, has real PII baked in.
# The public `latex-template.tex` uses placeholders; the skill prefers this
# `.local.tex` when it exists so locally-generated drafts have real values.
.claude/skills/drafting-resume-from-confirmed-assets/references/latex-template.local.tex
.agents/skills/drafting-resume-from-confirmed-assets/references/latex-template.local.tex
